# Paperclip Railway Environment Variables
# Copy this to Railway's environment variables dashboard

# Required: Authentication secret (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=<your-secret-here>

# Required: Public URL of your Railway deployment
PAPERCLIP_URL=https://<your-railway-domain>.railway.app

# Optional: Set to "public" to allow public access (with auth)
# Set to "local_trusted" for local-only access (default)
PAPERCLIP_AUTH_MODE=public

# Optional: Port (Railway sets this automatically via $PORT)
PORT=3100

# Optional: Database URL (if using external PostgreSQL instead of embedded)
# DATABASE_URL=postgresql://user:password@host:5432/paperclip
